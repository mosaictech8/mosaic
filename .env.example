# ══════════════════════════════════════════════════════════════
#  MOSAÏC INTERNATIONAL — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs réelles
#  ⚠️  Ne jamais committer le fichier .env
# ══════════════════════════════════════════════════════════════

# ── Supabase (obligatoire) ─────────────────────────────────────
# URL du projet : Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé SERVICE ROLE (jamais exposée côté client)
# Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_KEY=eyJhbGc...

# ── Authentification admin ─────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=ChangeThis2026!

# ── JWT (sessions admin — clé secrète forte) ───────────────────
JWT_SECRET=change-this-to-a-random-64-char-string

# ── Email de réception des formulaires ────────────────────────
CONTACT_EMAIL=contact@mozaikinternational.com

# ── SMTP (optionnel — notifications email) ─────────────────────
# Exemple avec Gmail : SMTP_HOST=smtp.gmail.com SMTP_USER=votre@gmail.com
# Exemple avec Resend : SMTP_HOST=smtp.resend.com SMTP_USER=resend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ── Environnement ─────────────────────────────────────────────
NODE_ENV=production
